{
    "name": "code-obfuscator",
    "displayName": "Code Obfuscator",
    "description": "Obfuscate and deobfuscate code in a folder.",
    "version": "0.0.1",
    "publisher": "yourPublisherName",
    "engines": {
      "vscode": "^1.60.0"
    },
    "categories": [
      "Other"
    ],
    "activationEvents": [
      "onCommand:extension.openObfuscatorUI"
    ],
    "main": "./out/extension.js",
    "contributes": {
      "commands": [
        {
          "command": "extension.openObfuscatorUI",
          "title": "Open Code Obfuscator UI"
        }
      ]
    },
    "scripts": {
      "vscode:prepublish": "npm run compile",
      "compile": "tsc -p ./",
      "watch": "tsc -watch -p ./",
      "pretest": "npm run compile"
    },
    "devDependencies": {
      "@types/node": "^14.0.0",
      "typescript": "^4.0.0",
      "vscode": "^1.1.37"
    }
  }
  